// === V2: iPhone 15 Pro safe height & gate logo guarantee ===
(function setVH(){ function apply(){ document.documentElement.style.setProperty('--vh',(window.innerHeight*0.01)+'px'); } apply(); window.addEventListener('resize',apply); })();

document.addEventListener('DOMContentLoaded',()=>{
  // Garantir logo GIF dentro do gate
  try{
    const g = document.querySelector('#kgc-gate');
    if(g){
      let brand = g.querySelector('.brand');
      if(!brand){
        brand = document.createElement('div');
        brand.className = 'brand';
        const card = g.querySelector('.card') || g;
        card.insertBefore(brand, card.firstChild);
      }
      if(!brand.querySelector('img')){
        const img = new Image();
        img.src = (window.LOGO_URL || 'assets/logo.gif');
        img.alt = 'KGC';
        img.className = 'kgc-logo';
        brand.textContent = '';
        brand.appendChild(img);
      }
    }
  }catch(e){}

  // Fluxo de intro -> carrinho
  const startBtn = document.getElementById('start-button');
  const startScreen = document.getElementById('start-screen');
  const cartIcon = document.getElementById('cart-icon');
  if(startScreen) startScreen.classList.add('min-100');
  if(startBtn){
    startBtn.addEventListener('click',()=>{
      document.body.classList.add('scene');
      if(startScreen) startScreen.style.display = 'none';
      if(cartIcon) cartIcon.style.display = 'flex';
      const bg = document.getElementById('bg-music'); if(bg){ try{ bg.volume=0.2; bg.play(); }catch(e){} }
    });
  }
});



// === V3: Hidden Admin (create user + login) and gate logo spin ===
(function(){
  const ADMIN_USERS_KEY = 'kgc_admin_users_v1';
  const ADMIN_SESSION_KEY = 'kgc_admin_session_v1';

  function isAdmin(){ return !!localStorage.getItem(ADMIN_SESSION_KEY); }
  function ensureAdminVisibility(){
    if(isAdmin()) document.body.classList.add('is-admin');
    else document.body.classList.remove('is-admin');
  }

  async function sha256(str){
    const buf = new TextEncoder().encode(str);
    const digest = await crypto.subtle.digest('SHA-256', buf);
    return Array.from(new Uint8Array(digest)).map(b=>b.toString(16).padStart(2,'0')).join('');
  }

  async function createAdminUser(username, password){
    const saltBytes = crypto.getRandomValues(new Uint8Array(16));
    const salt = Array.from(saltBytes).map(b=>b.toString(16).padStart(2,'0')).join('');
    const hash = await sha256(salt + password);
    const list = JSON.parse(localStorage.getItem(ADMIN_USERS_KEY)||'[]');
    list.push({u:username, s:salt, h:hash, ts:Date.now()});
    localStorage.setItem(ADMIN_USERS_KEY, JSON.stringify(list));
  }

  async function loginAdmin(username, password){
    const list = JSON.parse(localStorage.getItem(ADMIN_USERS_KEY)||'[]');
    const user = list.find(x=>x.u===username);
    if(!user) return false;
    const hash = await sha256(user.s + password);
    if(hash === user.h){
      localStorage.setItem(ADMIN_SESSION_KEY, JSON.stringify({u:username, ts:Date.now()}));
      ensureAdminVisibility();
      return true;
    }
    return false;
  }

  function logoutAdmin(){
    localStorage.removeItem(ADMIN_SESSION_KEY);
    ensureAdminVisibility();
  }

  function hasAnyAdmin(){
    const list = JSON.parse(localStorage.getItem(ADMIN_USERS_KEY)||'[]');
    return list.length > 0;
  }

  function buildModal(inner){
    const wrap = document.createElement('div');
    wrap.id = 'kgc-admin-login';
    wrap.style.cssText = 'position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,.75);display:flex;align-items:center;justify-content:center;padding:16px;';
    const box = document.createElement('div');
    box.style.cssText = 'width:min(460px,92vw);background:#111;border:2px solid #f5c542;border-radius:16px;padding:18px 16px;color:#eee;font-family:inherit;';
    box.innerHTML = inner;
    wrap.appendChild(box);
    document.body.appendChild(wrap);
    wrap.addEventListener('click', (e)=>{ if(e.target===wrap) wrap.remove(); });
    return wrap;
  }

  function showAdminLogin(){
    const createView = `
      <h3 style="margin:0 0 8px">Criar usuário admin</h3>
      <p style="opacity:.8;margin:0 0 12px">Defina seu usuário/senha. Fica salvo no seu navegador (localStorage).</p>
      <label>Usuário</label>
      <input id="admU" class="kgc-input" style="width:100%;margin:.25rem 0 0.75rem" placeholder="seu_usuario">
      <label>Senha</label>
      <input id="admP" type="password" class="kgc-input" style="width:100%;margin:.25rem 0 1rem" placeholder="••••••••">
      <div style="display:flex;gap:8px;justify-content:flex-end">
        <button id="admCancel" class="btn">Cancelar</button>
        <button id="admCreate" class="btn" style="background:#f5c542;color:#000">Criar</button>
      </div>`;

    const loginView = `
      <h3 style="margin:0 0 8px">Login admin</h3>
      <label>Usuário</label>
      <input id="admLU" class="kgc-input" style="width:100%;margin:.25rem 0 0.75rem" placeholder="seu_usuario">
      <label>Senha</label>
      <input id="admLP" type="password" class="kgc-input" style="width:100%;margin:.25rem 0 1rem" placeholder="••••••••">
      <div style="display:flex;gap:8px;justify-content:space-between">
        <button id="admLogout" class="btn" style="display:${isAdmin()?'inline-block':'none'}">Sair</button>
        <div style="flex:1"></div>
        <button id="admClose" class="btn">Fechar</button>
        <button id="admLogin" class="btn" style="background:#f5c542;color:#000">Entrar</button>
      </div>`;

    const modal = buildModal(hasAnyAdmin() ? loginView : createView);

    const close = ()=>modal.remove();

    const admCancel = modal.querySelector('#admCancel');
    if(admCancel) admCancel.onclick = close;

    const admCreate = modal.querySelector('#admCreate');
    if(admCreate){
      admCreate.onclick = async ()=>{
        const u = modal.querySelector('#admU').value.trim();
        const p = modal.querySelector('#admP').value;
        if(!u || !p){ alert('Preencha usuário e senha'); return; }
        await createAdminUser(u,p);
        alert('Admin criado. Faça login.');
        modal.remove(); showAdminLogin();
      };
    }

    const admLogin = modal.querySelector('#admLogin');
    if(admLogin){
      admLogin.onclick = async ()=>{
        const u = modal.querySelector('#admLU').value.trim();
        const p = modal.querySelector('#admLP').value;
        if(await loginAdmin(u,p)){
          modal.remove();
          // tenta abrir painel existente
          const adminBtn = document.getElementById('admin-fab') || document.querySelector('#admin, .admin, .admin-fab, .admin-bar [role="button"]');
          if(adminBtn){ adminBtn.click && adminBtn.click(); }
          else { alert('Admin logado. Painel disponível.'); }
        } else {
          alert('Usuário ou senha inválidos.');
        }
      };
    }

    const admClose = modal.querySelector('#admClose');
    if(admClose) admClose.onclick = close;

    const admLogout = modal.querySelector('#admLogout');
    if(admLogout) admLogout.onclick = ()=>{ logoutAdmin(); alert('Sessão encerrada.'); close(); };
  }

  // Trigger oculto: long-press na logo/brand (gate ou header)
  function attachSecretTrigger(){
    const target = document.querySelector('#kgc-gate .brand img, .header .brand img, .brand img, .kgc-logo');
    if(!target) return;
    let t; let pressed = false;
    const start = ()=>{ pressed = true; t = setTimeout(()=>{ if(pressed) showAdminLogin(); }, 700); };
    const end = ()=>{ pressed = false; clearTimeout(t); };
    ['mousedown','touchstart'].forEach(ev=> target.addEventListener(ev,start,{passive:true}));
    ['mouseup','mouseleave','touchend','touchcancel'].forEach(ev=> target.addEventListener(ev,end,{passive:true}));
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Marca admin atual
    ensureAdminVisibility();

    // Garante logo GIF spin no gate
    const g = document.querySelector('#kgc-gate .brand img');
    if(g){ g.classList.add('spin'); }

    // Atalhos
    document.addEventListener('keydown',(e)=>{
      if(e.ctrlKey && e.shiftKey && e.key.toLowerCase()==='a'){ e.preventDefault(); showAdminLogin(); }
    });

    attachSecretTrigger();
  });
})();



// ===============================
// Galeria de mídia / lookbook
// ===============================
document.addEventListener('DOMContentLoaded', function () {
  const grid = document.querySelector('.media-grid');
  const lightbox = document.getElementById('lightbox');
  const lightboxImage = document.getElementById('lightbox-image');
  const closeBtn = document.querySelector('.lightbox-close');

  if (!grid || !lightbox || !lightboxImage) {
    return; // página não é a de mídia
  }

  function openLightbox(src, alt) {
    lightboxImage.src = src;
    lightboxImage.alt = alt || 'Foto do lookbook KGC';
    lightbox.classList.remove('hidden');
    document.body.classList.add('no-scroll');
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    document.body.classList.remove('no-scroll');
  }

  grid.addEventListener('click', function (event) {
    const img = event.target.closest('img[data-full]');
    if (!img) return;
    const fullSrc = img.getAttribute('data-full') || img.src;
    openLightbox(fullSrc, img.alt);
  });

  if (closeBtn) {
    closeBtn.addEventListener('click', function (event) {
      event.stopPropagation();
      closeLightbox();
    });
  }

  lightbox.addEventListener('click', function (event) {
    if (event.target === lightbox) {
      closeLightbox();
    }
  });

  document.addEventListener('keyup', function (event) {
    if (event.key === 'Escape') {
      closeLightbox();
    }
  });

  // expõe para uso em atributos inline se necessário
  window.closeLightbox = closeLightbox;
});
